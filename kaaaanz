function goHome(){up({pg:"home",menu:false,user:null,own:"",ci:"",err:"",ok:"",sc:"",un:"",jn:"",busy:false});}
function resetUser(){if(st.own)DB.dl("u:"+st.own,1).then(function(){goHome();});else goHome();}

function poll(){
  DB.g("winner",1).then(function(w){if(w&&(!st.winner||st.winner.u!==w.u))up({winner:w});});
  if(st.own&&st.pg==="game"){
    DB.g("u:"+st.own,1).then(function(f){if(f&&f.step!==st.user.step)up({user:f});});
  }
}

function renderMedia(lm){
  if(!lm||!lm.media)return "";
  var m=lm.media;
  if(m.t==="svg")return '<div style="margin-bottom:16px">'+m.c+'</div>';
  if(m.t==="img")return '<div style="margin-bottom:16px"><img src="data:'+m.mime+';base64,'+m.c+'" class="imgpzl"/></div>';
  if(m.t==="morse")return '<div style="margin-bottom:16px"><div class="morse">'+m.c+'</div></div>';
  if(m.t==="coord"){var lines=m.c.split("\\n");return '<div style="margin-bottom:16px"><div class="coord">'+lines.join("<br>")+'</div></div>';}
  if(m.t==="chem")return '<div style="margin-bottom:16px"><div class="chem">'+m.c+'</div></div>';
  if(m.t==="audio")return '<div style="margin-bottom:16px"><div class="audiowrap"><audio controls style="width:100%"><source src="data:'+m.mime+';base64,'+m.c+'" type="'+m.mime+'"/></audio></div></div>';
  return "";
}
