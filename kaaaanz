  ls:function(p,s){return window.storage.list(p,!!s).then(function(r){return r&&r.keys?r.keys:[];}).catch(function(){return[];});}
};

var st={pg:"home",mode:"new",un:"",jn:"",sc:"",ci:"",apw:"",
  user:null,own:"",winner:null,err:"",ok:"",busy:false,
  aUs:[],aLd:false,showPw:false,menu:false};

function up(o){Object.assign(st,o);draw();}
function eM(m){up({err:m,ok:""});setTimeout(function(){if(st.err===m)up({err:"",ok:"",busy:false});},3500);}
function oM(m){up({ok:m,err:""});setTimeout(function(){if(st.ok===m)up({ok:"",err:""});},2500);}
function gLM(id){for(var i=0;i<LM.length;i++){if(LM[i].id===id)return LM[i];}return null;}
function cLM(){if(!st.user)return null;var p=PATHS[st.user.pI];return st.user.step<p.length?gLM(p[st.user.step]):null;}
function pct(){return st.user?Math.round(st.user.step/PATHS[st.user.pI].length*100):0;}

function newUser(){
  var un=st.un.trim();if(!un){eM("\u0623\u062f\u062e\u0644 \u0627\u0633\u0645\u0627\u064b");return;}
  up({busy:true});
  DB.g("u:"+un,1).then(function(ex){
    if(ex){eM("\u0647\u0630\u0627 \u0627\u0644\u0627\u0633\u0645 \u0645\u0648\u062c\u0648\u062f\u060c \u0627\u062e\u062a\u0631 \u0627\u0633\u0645\u0627\u064b \u0622\u062e\u0631");up({busy:false});return;}
    DB.ls("u:",1).then(function(keys){
      var pI=keys.length%PATHS.length;
      var user={username:un,pI:pI,step:0,started:false,done:false};
      DB.sv("u:"+un,user,1).then(function(){up({user:user,own:un,pg:"ready",busy:false});});
    });
  });
}
function joinUser(){
  var jn=st.jn.trim();if(!jn){eM("\u0623\u062f\u062e\u0644 \u0627\u0644\u0627\u0633\u0645");return;}
  up({busy:true});
  DB.g("u:"+jn,1).then(function(user){
    if(!user){eM("\u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645 \u063a\u064a\u0631 \u0645\u0648\u062c\u0648\u062f");up({busy:false});return;}
    up({user:user,own:user.username,pg:user.started?"game":"ready",busy:false});
  });
}
function startGame(){
  if(st.sc!=="2010"){eM("\u0643\u0648\u062f \u0627\u0644\u0628\u062f\u0621 \u062e\u0627\u0637\u0626");return;}
  DB.g("u:"+st.own,1).then(function(base){
    var u=Object.assign({},base||st.user,{started:true,startTime:new Date().toISOString()});
    DB.sv("u:"+st.own,u,1).then(function(){up({user:u,pg:"game"});});
  });
}
function submitCode(){
  var lm=cLM();if(!lm)return;
  if(st.ci!==lm.code){eM("\u0627\u0644\u0643\u0648\u062f \u062e\u0627\u0637\u0626 \u274c");up({ci:""});return;}
  up({busy:true});
  DB.g("u:"+st.own,1).then(function(base){
    var cur=base||st.user;
    var path=PATHS[cur.pI];
    var isLast=cur.step===path.length-1;
    var u=Object.assign({},cur,{step:cur.step+1});
    if(isLast){u.done=true;u.ft=new Date().toISOString();}
    DB.sv("u:"+st.own,u,1).then(function(){
      if(isLast){
        DB.sv("winner",{u:st.own,t:u.ft},1).then(function(){up({winner:{u:st.own},user:u,pg:"win",ci:"",busy:false});});
      } else {
        oM("\u2705 \u0623\u062d\u0633\u0646\u062a! \u062a\u0648\u062c\u0651\u0647 \u0644\u0644\u0645\u0639\u0644\u0645 \u0627\u0644\u062a\u0627\u0644\u064a");
        up({user:u,ci:"",busy:false});
      }
    });
  });
}
function adminLogin(){
  if(st.apw!=="200100"){eM("\u0643\u0644\u0645\u0629 \u0627\u0644\u0633\u0631 \u062e\u0627\u0637\u0626\u0629");return;}
  up({pg:"admin",aLd:true,apw:"",showPw:false});loadAdmin();
}
function loadAdmin(){
  up({aLd:true});
  DB.ls("u:",1).then(function(keys){
    var aUs=[];var i=0;
    function next(){
      if(i>=keys.length){
        DB.g("winner",1).then(function(w){up({aUs:aUs,winner:w||st.winner,aLd:false});});return;
      }
      DB.g(keys[i],1).then(function(d){if(d)aUs.push(d);i++;next();});
    }
    next();
  });
}
function delUser(un){DB.dl("u:"+un,1).then(function(){loadAdmin();});}
