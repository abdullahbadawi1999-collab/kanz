      var u=us[i];var tot=PATHS[u.pI].length;
      var p=Math.round(u.step/tot*100);
      var ss=u.done?"\u2705 \u0623\u0646\u0647\u0649":u.started?"\u0627\u0644\u0645\u062d\u0637\u0629 "+(u.step+1)+" / "+tot:"\u23F8 \u0644\u0645 \u064a\u0628\u062f\u0623";
      var lm=u.started&&!u.done&&u.step<tot?gLM(PATHS[u.pI][u.step]):null;
      rows+='<div class="urow"><div style="flex:1;min-width:0">'+
        '<strong style="font-size:14px;display:block;margin-bottom:4px">'+u.username+'</strong>'+
        '<p class="m" style="font-size:12px">'+ss+(lm?' \xB7 \u0645\u0639\u0644\u0645 '+lm.id+' / '+tot:'')+'  ('+p+'%)</p>'+
        '<div class="pb" style="height:5px;margin-top:5px;margin-bottom:0">'+
        '<div class="pbf" style="width:'+p+'%"></div></div></div>'+
        '<button class="btn btsm btr" data-del="'+u.username+'" style="flex-shrink:0;padding:8px 12px;font-size:12px;margin-bottom:0">\u062d\u0630\u0641</button></div>';
    }
  }
  return '<div class="hd">'+homeBtn()+
    '<h1 style="font-size:18px">\u0644\u0648\u062d\u0629 \u0627\u0644\u062a\u062d\u0643\u0645</h1>'+
    '<button class="btn btsm btb" id="barf" style="width:auto">\u21BB</button></div>'+
    (st.winner?'<div class="cg" style="text-align:center">'+
    '<p style="font-size:12px;color:#854F0B;margin-bottom:4px">\u{1F3C6} \u0627\u0644\u0641\u0627\u0626\u0632</p>'+
    '<strong style="font-size:16px">'+st.winner.u+'</strong>'+
    '<button class="btn btsm btr" id="bcw" style="width:100%;margin-top:10px">\u0645\u0633\u062d \u0646\u062a\u064a\u062c\u0629 \u0627\u0644\u0641\u0648\u0632</button></div>':'')+
    '<div class="c"><h2 style="margin-bottom:4px">\u0627\u0644\u0645\u062a\u0633\u0627\u0628\u0642\u0648\u0646 ('+us.length+')</h2>'+rows+'</div>';
}

function bind(){
  function on(id,fn){var e=document.getElementById(id);if(e)e.addEventListener("click",fn);}
  var homeEls=document.querySelectorAll("#bhme");
  for(var h=0;h<homeEls.length;h++){homeEls[h].addEventListener("click",goHome);}
  on("bta",function(){up({pg:"auth",err:"",ok:"",mode:"new"});});
  on("btadm",function(){up({showPw:!st.showPw,err:"",ok:""});});
  on("badm",adminLogin);
  on("barf",loadAdmin);on("bcw",clrWinner);
  var dels=document.querySelectorAll("[data-del]");
  for(var i=0;i<dels.length;i++){
    (function(el){el.addEventListener("click",function(){delUser(el.dataset.del);});})(dels[i]);
  }
  on("tnew",function(){up({mode:"new",err:"",ok:"",busy:false});});
  on("tjn",function(){up({mode:"join",err:"",ok:"",busy:false});});
  on("bnew",newUser);on("bjn",joinUser);
  on("bst",startGame);
  on("bmn",function(){up({menu:!st.menu});});
  on("bmc",function(){up({menu:false});});
  on("bex1",goHome);on("brst",resetUser);
  on("bcd",submitCode);

  function wire(id,key,opts){
    var e=document.getElementById(id);if(!e)return;
    e.addEventListener("input",function(){
      var v=e.value;
      if(opts&&opts.num)v=v.replace(/\D/g,"").slice(0,4);
      st[key]=v;
      if(opts&&opts.btn){var b=document.getElementById(opts.btn);if(b)b.disabled=(v.length!==4);}
    });
    if(opts&&opts.enter)e.addEventListener("keydown",function(ev){if(ev.key==="Enter")opts.enter();});
  }
  wire("iun","un",{enter:newUser});
  wire("ijn","jn",{enter:joinUser});
  wire("isc","sc",{num:true,enter:startGame});
  wire("ici","ci",{num:true,btn:"bcd",enter:submitCode});
  wire("iapw","apw",{enter:adminLogin});
}

setTimeout(function(){draw();setInterval(poll,5000);},80);

</script>
